# =============================================================================
# Fifoteca Production Environment Configuration
# =============================================================================
# Copy this file to .env and replace all <change-me> values
# =============================================================================

# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------
DOMAIN=fif.calvo.dev

# Frontend URL (used by backend to generate links in emails, CORS, etc.)
FRONTEND_HOST=https://fif.calvo.dev

# Environment: local, staging, production
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# Project Settings
# -----------------------------------------------------------------------------
PROJECT_NAME="Fifoteca"
STACK_NAME=fifoteca

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed CORS origins
BACKEND_CORS_ORIGINS="https://fif.calvo.dev,https://www.fif.calvo.dev"

# Generate a secure secret key: openssl rand -hex 32
SECRET_KEY=<change-me>

# Superuser credentials (first admin user)
FIRST_SUPERUSER=admin@fif.calvo.dev
FIRST_SUPERUSER_PASSWORD=<change-me>

# -----------------------------------------------------------------------------
# Email Configuration (optional - for password reset, notifications)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=noreply@fif.calvo.dev
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=fifoteca
POSTGRES_USER=fifoteca
POSTGRES_PASSWORD=<change-me>

# -----------------------------------------------------------------------------
# Error Tracking (optional)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Docker Image Names
# -----------------------------------------------------------------------------
# For local builds, these can stay as is
# For CI/CD, set to your registry path (e.g., ghcr.io/user/fifoteca-backend)
DOCKER_IMAGE_BACKEND=fifoteca-backend
DOCKER_IMAGE_FRONTEND=fifoteca-frontend

# -----------------------------------------------------------------------------
# Port & URL Configuration (for compose.deploy.yml)
# -----------------------------------------------------------------------------
HOST_BACKEND_PORT=18437
HOST_FRONTEND_PORT=53172

# Vite API URL (frontend uses this to call the backend at build time)
VITE_API_URL=https://fif.calvo.dev
